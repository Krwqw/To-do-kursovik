{
  "ConnectionStrings": {
    "DefaultConnection": "Server=127.0.0.1;Port=3306;Database=todolist;User=root;Password=;"//строка подключения к БД
  },
  "JwtSettings": { //настройка и создание jwt токина
    "SecretKey": "SuperDuperSecretKeyForToDoProjectNewNew", //секретный ключ для подписи токенов
    "Issuer": "TodoListAPI", //проверка выдачи токина сервером
    "Audience": "TodoListClient", //проверка для кого токен
    "ExpirationInMinutes": 60 //работоспособность токена 60 минут
  },
  "Logging": {//настройка логирования
    "LogLevel": {
      "Default": "Information",//запись о запросах
      "Microsoft.AspNetCore": "Warning"//записи только об ошибках
    }
  },
}